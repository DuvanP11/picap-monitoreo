# ──────────────────────────────────────────────────────────────
# Picap Monitoreo — Variables de entorno
# ──────────────────────────────────────────────────────────────
# Copia este archivo a `.env` y rellena los valores reales.
# `.env` está en .gitignore — los secretos nunca se commitean.

# ── ClickHouse (origen de datos) ──────────────────────────────
CLICKHOUSE_HOST=clickhouse.picap.io
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=dperilla
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=picapmongoprod

# ── Sesiones del dashboard (HMAC) ─────────────────────────────
# String secreto para firmar tokens de sesión. Cualquier string largo aleatorio.
# Ej: openssl rand -hex 32
TOKEN_SECRET=cambiar_por_un_string_aleatorio_largo

# ── Admin inicial (solo se usa una vez al crear la tabla) ─────
# Si están definidas, al arrancar y no haber admin, se crea uno con esta clave.
# Si están vacías, hay que crear el admin manualmente desde el panel.
ADMIN_INITIAL_PASSWORD=
ADMIN_INITIAL_EMAIL=admin@picap.com

# ── Admin de emergencia (login fallback si CH no responde) ────
# Si está vacío, no hay login de emergencia.
ADMIN_EMERGENCY_PASSWORD=
ADMIN_EMERGENCY_EMAIL=admin@picap.com

# ── SMTP (para recordatorios y reset de contraseña) ───────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Flask ─────────────────────────────────────────────────────
PORT=5050
